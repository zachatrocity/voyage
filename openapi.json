{
  "openapi": "3.0.3",
  "info": {
    "description": "A self-hosted travel plan aggregator that searches through emails",
    "title": "Voyage API",
    "termsOfService": "http://swagger.io/terms/",
    "contact": {
      "name": "API Support",
      "email": "support@example.com"
    },
    "license": {
      "name": "MIT",
      "url": "https://opensource.org/licenses/MIT"
    },
    "version": "1.0"
  },
  "servers": [
    {
      "url": "http://localhost:8181/api/v1"
    }
  ],
  "paths": {
    "/email/{id}": {
      "get": {
        "summary": "Get email by ID",
        "description": "Retrieve a single email by its message ID",
        "tags": [
          "email"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Thread ID"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/notmuch_EmailResult"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "operationId": "get_email"
      }
    },
    "/email/{id}/tags/{tag}": {
      "post": {
        "summary": "Tag an email",
        "description": "Add a tag to an email by its message ID",
        "tags": [
          "email"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Message ID"
          },
          {
            "name": "tag",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Tag to add"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/notmuch_EmailResult"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "operationId": "tag_email"
      }
    },
    "/email/{id}/trip/{tripId}": {
      "post": {
        "summary": "Associate an email with a trip",
        "description": "Remove any existing trip:* tags and apply trip:{tripId} to the email",
        "tags": [
          "email",
          "trips"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Email message ID"
          },
          {
            "name": "tripId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Trip ID"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/handlers_associateTripEmailResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "operationId": "associate_email_trip"
      }
    },
    "/health": {
      "get": {
        "summary": "Health check endpoint",
        "description": "Get the health status of the API and database connection",
        "tags": [
          "health"
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": true
                }
              }
            }
          }
        },
        "operationId": "health_check"
      }
    },
    "/search": {
      "get": {
        "summary": "Search emails",
        "description": "Search for emails using notmuch query",
        "tags": [
          "search"
        ],
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Search query"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Result limit"
          },
          {
            "name": "sort",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Sort order (oldest_first, newest_first)"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/notmuch_SearchResults"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "operationId": "search_emails"
      }
    },
    "/trips": {
      "get": {
        "summary": "List all trips",
        "description": "Get a list of all trips",
        "tags": [
          "trips"
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/handlers_tripResponse"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "operationId": "list_trips"
      },
      "post": {
        "summary": "Create a new trip",
        "description": "Create a trip with a name and date range",
        "tags": [
          "trips"
        ],
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/handlers_tripResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "409": {
            "description": "Conflict",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/handlers_createTripRequest"
              }
            }
          }
        },
        "operationId": "create_trip"
      }
    },
    "/trips/{id}/emails": {
      "get": {
        "summary": "List emails for a trip",
        "description": "Get all emails tagged with a specific trip, sorted chronologically",
        "tags": [
          "email",
          "trips"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Trip ID"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/handlers_tripEmailsResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "operationId": "get_trip_emails"
      }
    }
  },
  "components": {
    "schemas": {
      "handlers_TripEmailItem": {
        "description": "An email associated with a trip",
        "type": "object",
        "properties": {
          "date": {
            "type": "string"
          },
          "filename": {
            "type": "string"
          },
          "from": {
            "type": "string"
          },
          "message_id": {
            "type": "string"
          },
          "subject": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "thread_id": {
            "type": "string"
          }
        }
      },
      "handlers_associateTripEmailResponse": {
        "type": "object",
        "properties": {
          "message_id": {
            "type": "string",
            "example": "<abc123@gmail.com>"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": [
              "inbox",
              "trip:2026-cruise",
              "travel"
            ]
          },
          "trip_id": {
            "type": "string",
            "example": "2026-cruise"
          }
        }
      },
      "handlers_createTripRequest": {
        "type": "object",
        "properties": {
          "date_range": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "handlers_tripEmailsResponse": {
        "type": "object",
        "properties": {
          "emails": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/handlers_TripEmailItem"
            }
          },
          "trip_id": {
            "type": "string",
            "example": "2026-cruise"
          }
        }
      },
      "handlers_tripResponse": {
        "type": "object",
        "properties": {
          "confirmed_count": {
            "type": "integer"
          },
          "created_at": {
            "type": "string"
          },
          "date_range": {
            "type": "string"
          },
          "email_count": {
            "type": "integer"
          },
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "notmuch_EmailResult": {
        "description": "Email search result",
        "type": "object",
        "properties": {
          "body_preview": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "date": {
            "type": "string",
            "example": "2023-01-01T12:00:00Z"
          },
          "filename": {
            "type": "string",
            "example": "/path/to/email.eml"
          },
          "from": {
            "type": "string",
            "example": "sender@example.com"
          },
          "message_id": {
            "type": "string",
            "example": "<12345@example.com>"
          },
          "subject": {
            "type": "string",
            "example": "Flight Confirmation"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": [
              "travel",
              "flight"
            ]
          },
          "thread_id": {
            "type": "string",
            "example": "thread123"
          },
          "trip_id": {
            "type": "string"
          }
        }
      },
      "notmuch_SearchResults": {
        "description": "Search results containing matching emails",
        "type": "object",
        "properties": {
          "count": {
            "type": "integer",
            "example": 42
          },
          "query": {
            "type": "string",
            "example": "subject:flight"
          },
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/notmuch_EmailResult"
            }
          }
        }
      }
    }
  }
}